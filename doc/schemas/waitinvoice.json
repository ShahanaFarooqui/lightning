        }
      },
      "response": {
        "label": "inv2",
        "bolt11": "lnbcrt20n1pne035qsp5g0v5nxljyscl7y96rafhwh2t5n569l4fxalhx554em395rz05j6spp5scgjfgrqem7ny3747gk6yyrkxn3v2k2ttdf5y8xankkfvf53yzvsdq8d9h8vvsxqyjw5qcqp99qxpqysgqsc95qzqhwg6ze32nzkvv6vxrrc5l7nxaa0dyrlahcsmau635fczjjafqe7wncy3zqg7gdk54dq4c8u5hgej52p8vpuezvm932jy8p0qpgqfdu5",
        "payment_hash": "861124a060cefd3247d5f22da2107634e2c5594b5b53421cdd9dac9626912099",
        "amount_msat": 2000,
        "status": "paid",
        "pay_index": 5,
        "amount_received_msat": 2000,
        "paid_at": 1738000000,
        "payment_preimage": "08377744ca98506908377744ca98506908377744ca98506908377744ca985069",
